# Copy this file to `.env` and replace the values.
# Never commit a real `.env` with production secrets to git.

# PostgreSQL connection string (Neon, local Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# NextAuth v5 — use a long random string in production (e.g. openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-secret"

# Canonical site URL (Auth.js v5). On Vercel use https://your-project.vercel.app (no trailing slash)
AUTH_URL="http://localhost:3000"

# Legacy alias; some hosts still expect this — match AUTH_URL in production
NEXTAUTH_URL="http://localhost:3000"

# Optional: canonical site URL for metadata / Open Graph (defaults work on Vercel via VERCEL_URL)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
